rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /reports/{reportId} {
      // Allow public read access
      allow read: if true;

      // Allow any authenticated user to create or update reports
      allow create: if request.auth != null
                    && request.resource.data.reportedBy == request.auth.uid;
      allow update: if request.auth != null;

      // Prevent document deletion at the database level
      allow delete: if false;

      match /comments/{commentId} {
        // Allow public read access
        allow read: if true;

        // Allow any authenticated user to write comments.
        allow write: if request.auth != null;
      }
    }

    // Users can only manage their own user-specific data (e.g., language preference).
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Notifications - users can read their own notifications, authenticated users can create
    match /notifications/{notificationId} {
      allow read: if request.auth != null && (resource.data.userId == request.auth.uid || resource.data.userId == null);
      allow create: if request.auth != null;
      allow update: if request.auth != null && (resource.data.userId == request.auth.uid || resource.data.userId == null);
      allow delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }

    // History logs - authenticated users can read and create, but not modify
    match /history/{historyId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if false;
    }

    // Audit logs can be created by any authenticated user but cannot be modified or deleted.
    match /logs/{logId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if false;
    }

    // Violation terms - public read, authenticated write
    match /violationTerms/{termId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Sub violation types - public read, authenticated write
    match /subViolationTypes/{typeId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Place types - public read, authenticated write
    match /placeTypes/{placeId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Teams - authenticated users can read and write
    match /teams/{teamId} {
      allow read, write: if request.auth != null;
    }

    // Posts - authenticated users can read and write
    match /posts/{postId} {
      allow read, write: if request.auth != null;
    }

    // Province GeoJSON - public read, authenticated write
    match /provinceGeoJSON/{geoId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Supporters collection - public read, authenticated write
    match /supporters/{supporterId} {
      // Allow public read access so all users can see supporters in footer
      allow read: if true;
      
      // Only authenticated users can manage supporters
      allow write: if request.auth != null;
    }

    // Tips collection - public read, authenticated write
    match /tips/{tipId} {
      // Allow public read access so all users can see tips
      allow read: if true;
      
      // Only authenticated users can create or update tips
      allow create: if request.auth != null
                    && request.resource.data.createdBy == request.auth.uid;
      allow update: if request.auth != null;
      allow delete: if false;
    }
  }
}
