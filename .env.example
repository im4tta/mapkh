# Copy this file to `.env.local` and fill in values

# --- Client Firebase (required) ---
NEXT_PUBLIC_FIREBASE_API_KEY=""
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=""
NEXT_PUBLIC_FIREBASE_PROJECT_ID=""
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=""
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=""
NEXT_PUBLIC_FIREBASE_APP_ID=""

# --- Firebase Admin (server-side for NextAuth adapter) ---
FIREBASE_ADMIN_PROJECT_ID=""
FIREBASE_ADMIN_CLIENT_EMAIL=""
# Wrap private key in quotes; keep \n line breaks as actual newlines or escaped
FIREBASE_ADMIN_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"

# --- NextAuth ---
NEXTAUTH_URL="http://localhost:3000"
# Generate a strong secret: e.g. `node -e "console.log(crypto.randomBytes(32).toString('hex'))"`
NEXTAUTH_SECRET="replace-with-a-strong-secret"

# --- Google APIs (maps + drive integration) ---
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=""
GOOGLE_DRIVE_PARENT_FOLDER_ID="" # Only the folder ID, not the full URL
GCP_SERVICE_ACCOUNT_EMAIL=""      # From your service account JSON
GCP_SERVICE_ACCOUNT_PRIVATE_KEY="" # From your service account JSON

# --- Admin Configuration ---
# Comma-separated list of Firebase Auth UIDs with admin privileges
ADMIN_UIDS=""
# Public variant for client-side admin checks (same value)
NEXT_PUBLIC_ADMIN_UIDS=""

# --- Web Push / VAPID ---
NEXT_PUBLIC_VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_SUBJECT="mailto:support@mapkh.com"

# --- Analytics ---
NEXT_PUBLIC_DATABUDDY_CLIENT_ID=""